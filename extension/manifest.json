{
  "manifest_version": 3,
  "name": "FAKE-SHA",
  "version": "0.1.0",
  "description": "Fake news detection with explainable AI.",
  "action": {
    "default_title": "FAKE-SHA",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
